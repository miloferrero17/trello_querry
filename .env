APP_NAME=sql-vector-search-api
APP_ENV=dev
LOG_LEVEL=INFO

# Pinecone
PINECONE_API_KEY=pcsk_4pcHwg_6XdPvkE7ZeNXFq9p7m1SQSZGFWD7qNrAR1cEbhcoC3q4eUWuScPmnSyZNZbP1CB
PINECONE_INDEX=trello
PINECONE_NAMESPACE=trello

# If top_k is omitted in filters-only mode, service tries to fetch "all matches" by filters
# via Pinecone fetch_by_metadata pagination. Safety caps:
MAX_RESULTS=5000
PAGE_SIZE=200

# OpenAI (only needed when query_text is provided)
OPENAI_API_KEY=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
OPENAI_EMBED_MODEL=text-embedding-3-small

# Default when query_text is provided AND top_k omitted (semantic search needs a top_k)
DEFAULT_QUERY_TOP_K=50
